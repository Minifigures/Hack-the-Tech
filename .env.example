# EvalForge environment template
# Copy to .env. Leave LLM keys empty to run in deterministic mock mode.

# LLM providers (all optional — leave blank for mock mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Storage
EVALFORGE_DB_URL=sqlite:///./data/evalforge.db

# LLM defaults
EVALFORGE_DEFAULT_MODEL=claude-haiku-4-5-20251001
EVALFORGE_USE_MOCK=auto      # auto | always | never

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
