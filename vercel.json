{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{backend/app/**,data/kb/**,data/evals/golden.json}"
    }
  },
  "rewrites": [
    { "source": "/api/:evpath*", "destination": "/api/index?evpath=:evpath" }
  ]
}
